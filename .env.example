# 数据库连接字符串（Neon Serverless PostgreSQL）
# 在 https://neon.tech 创建免费数据库后获取
# 格式: postgresql://user:password@host/dbname?sslmode=require
# 部署到 Cloudflare Pages 时，必须在环境变量中配置此值
DATABASE_URL="postgresql://..."

# Upstash Redis（用于速率限制，可选配置）
# 在 https://upstash.com 创建免费 Redis 后获取
# 如果不配置，速率限制功能将自动跳过
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Cloudflare Pages 配置
# NODE_ENV: 设置为 production 以启用生产环境优化
NODE_ENV="production"
